{
  "name": "@pulseboard/react-native",
  "version": "0.1.0",
  "description": "Official PulseBoard SDK for React Native",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/mrarslanark/pulseboard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrarslanark/pulseboard"
  },
  "bugs": {
    "email": "m.arslanmushtaqahmed@gmail.com",
    "url": "https://github.com/mrarslanark/pulseboard"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "ios",
    "android",
    "react-native.config.js",
    "PulseBoardSDK.podspec"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "devDependencies": {
    "@types/react": "*",
    "@types/react-native": "*",
    "typescript": "*",
    "tsup": "*"
  },
  "keywords": [
    "react-native",
    "monitoring",
    "observability",
    "crash-reporting",
    "error-tracking",
    "analytics",
    "pulseboard"
  ],
  "author": {
    "email": "m.arslanmushtaqahmed@gmail.com",
    "name": "Arslan Mushtaq",
    "url": "https://arslanmushtaq.com"
  }
}
